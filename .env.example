SHOPIFY_AUTOMATIONS_CLIENT_ID=
SHOPIFY_AUTOMATIONS_CLIENT_SECRET=
SHOPIFY_AUTOMATIONS_REDIRECT_URI=
SHOPIFY_AUTOMATIONS_SCOPES=read_orders,read_fulfillments
SQUARESPACE_OAUTH_CLIENT_ID=
SQUARESPACE_OAUTH_CLIENT_SECRET=
SQUARESPACE_OAUTH_REDIRECT_URI=
SQUARESPACE_OAUTH_AUTHORIZATION_URL=https://login.squarespace.com/api/1/login/oauth/provider/authorize
SQUARESPACE_OAUTH_TOKEN_URL=https://login.squarespace.com/api/1/login/oauth/provider/tokens
SQUARESPACE_API_BASE=https://api.squarespace.com
SQUARESPACE_OAUTH_SCOPES="website.orders.read website.webhook_subscriptions.read_write"
WIX_APP_ID=
WIX_APP_SECRET=
WIX_INSTALL_URL=
WIX_OAUTH_REDIRECT_URI=
WIX_OAUTH_TOKEN_URL=https://www.wixapis.com/oauth2/token
WIX_API_BASE=https://www.wixapis.com
AUTOMATION_OAUTH_STATE_CACHE_STORE=database

# QuickBooks Online (read/import connector; tenant tokens are stored encrypted in integration_connections)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=production
QUICKBOOKS_API_BASE=
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
QUICKBOOKS_MINOR_VERSION=75
QUICKBOOKS_OAUTH_STATE_CACHE_STORE=file
MOBILE_CATALOG_FAKE_ENABLED=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
REDIS_QUEUE_CONNECTION=default

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Production embedded-admin performance cutover (after Redis preflight):
