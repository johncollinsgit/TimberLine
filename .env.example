APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production canonical example: APP_URL=https://app.theeverbranch.com
FORTIFY_ALLOW_REGISTRATION=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_CONNECTION=null
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Keep host-only cookies during dual-domain migration so legacy and canonical
# hosts do not share an overly broad cookie scope.
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# Shopify embedded admin production cookies:
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none
# SESSION_PARTITIONED_COOKIE=true
SHOPIFY_EMBEDDED_PERF_PROFILING_ENABLED=false
SHOPIFY_EMBEDDED_PERF_SLOW_QUERY_MS=25
SHOPIFY_EMBEDDED_DEEP_PROFILE_ENABLED=false
SHOPIFY_EMBEDDED_JOURNEY_CACHE_TTL_SECONDS=60
SHOPIFY_API_VERSION=2026-01
SHOPIFY_SCOPES=read_products,read_orders,read_all_orders,read_reports,read_analytics,read_customers,write_customers,read_discounts,write_discounts,read_pixels,write_pixels,read_customer_events
SHOPIFY_ALLOW_ENV_TOKEN_FALLBACK=false
# Stores used when commands run without explicit --store.
SHOPIFY_ACTIVE_STORE_KEYS=retail
# Launch-critical store keys (retail-first launch model).
SHOPIFY_REQUIRED_STORE_KEYS=retail

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
REDIS_QUEUE_CONNECTION=default

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Production embedded-admin performance cutover (after Redis preflight):
# SESSION_DRIVER=redis
# SESSION_CONNECTION=default
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# REDIS_QUEUE_CONNECTION=default
# REDIS_DB=0
# REDIS_CACHE_DB=1
# REDIS_QUEUE_DB=2

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.theeverbranch.com/auth/google/callback
GOOGLE_LOGIN_AUTO_PROVISION=true
# GOOGLE_LOGIN_ALLOWED_DOMAINS=theforestrystudio.com

# Canonical host model (runtime + outbound): Everbranch
TENANCY_CANONICAL_SCHEME=https
TENANCY_CANONICAL_BASE_DOMAIN=theeverbranch.com
TENANCY_CANONICAL_PUBLIC_HOST=theeverbranch.com
TENANCY_CANONICAL_LANDLORD_HOST=app.theeverbranch.com
# Restricts tenant slug host resolution to explicit base domains.
# Include local dev domains when needed (example: theeverbranch.test).
TENANCY_TENANT_BASE_DOMAINS=theeverbranch.com

# Legacy hosts are edge-redirect only after cutover; keep runtime acceptance disabled.
TENANCY_LEGACY_BASE_DOMAINS=
TENANCY_LEGACY_PUBLIC_HOSTS=
TENANCY_LEGACY_LANDLORD_HOSTS=
TENANCY_LEGACY_PUBLIC_REDIRECT_ENABLED=false
TENANCY_LEGACY_PUBLIC_REDIRECT_STATUS=302

AUTH_FLAGSHIP_TENANT_SLUG=modern-forestry
AUTH_FLAGSHIP_HOSTS=app.theeverbranch.com,theeverbranch.com
# Optional JSON host -> tenant slug map, for example:
# AUTH_TENANT_HOST_MAP={"acme.theeverbranch.com":"acme"}
AUTH_TENANT_HOST_MAP=
# Landlord/operator host config:
# - TENANCY_LANDLORD_PRIMARY_HOST is used for canonical route generation
# - production canonical host: app.theeverbranch.com
# - local example host set: app.theeverbranch.test
# - keep roles as "admin" unless you intentionally broaden access
# - keep emails blank unless you want an extra explicit allowlist
TENANCY_LANDLORD_PRIMARY_HOST=app.theeverbranch.com
TENANCY_LANDLORD_HOSTS=app.theeverbranch.com
TENANCY_LANDLORD_OPERATOR_ROLES=admin
TENANCY_LANDLORD_OPERATOR_EMAILS=
AUTH_PORTAL_NAME=Backstage
AUTH_FALLBACK_TENANT_LABEL="Modern Forestry"
PRODUCT_CONTACT_EMAIL_DOMAIN=theeverbranch.com
GOOGLE_GBP_ENABLED=false
GOOGLE_GBP_CLIENT_ID=
GOOGLE_GBP_CLIENT_SECRET=
GOOGLE_GBP_REDIRECT_URI=https://app.theeverbranch.com/marketing/candle-cash/google-business/callback
GOOGLE_GBP_SCOPES="https://www.googleapis.com/auth/business.manage"
GOOGLE_CALENDAR_API_KEY=
ASANA_SKYLIGHT_CALENDAR_ID=e4790b1a07ff610489e40c5fb28d50f4f8b74dc2d4b24db2a9b13bef0df39541@group.calendar.google.com
FEATURE_MARKET_EVENTS_PANEL=true

# Marketing storefront / Shopify proxy verification
MARKETING_SHOPIFY_SIGNING_SECRET=
MARKETING_SHOPIFY_APP_PROXY_ENABLED=true
MARKETING_SHOPIFY_APP_PROXY_SECRET=
MARKETING_SHOPIFY_SIGNATURE_TTL_SECONDS=300
MARKETING_SHOPIFY_APP_PROXY_TTL_SECONDS=900
MARKETING_SHOPIFY_ALLOW_LEGACY_TOKEN=false
MARKETING_SHOPIFY_BIRTHDAY_NAMESPACE=forestry_marketing
MARKETING_SHOPIFY_BIRTHDAY_WRITE_GROWAVE_ALIASES=true

# Growave private API (OAuth client credentials)
MARKETING_GROWAVE_ENABLED=false
MARKETING_GROWAVE_BASE_URL=https://api.growave.io
MARKETING_GROWAVE_CLIENT_ID=
MARKETING_GROWAVE_CLIENT_SECRET=
MARKETING_GROWAVE_SCOPE="read_customer read_review read_reward"
MARKETING_GROWAVE_SHOP=
MARKETING_GROWAVE_TIMEOUT_SECONDS=20
MARKETING_GROWAVE_RETRY_ATTEMPTS=3
MARKETING_GROWAVE_REQUEST_MIN_INTERVAL_MS=300
MARKETING_GROWAVE_REQUEST_JITTER_MS=100
MARKETING_GROWAVE_BACKOFF_BASE_MS=1000
MARKETING_GROWAVE_BACKOFF_MAX_MS=15000
MARKETING_GROWAVE_CANDIDATE_DELAY_MS=50
MARKETING_GROWAVE_PAGE_DELAY_MS=150

# Meta Ads spend ingestion (Phase 5 advisory readiness)
MARKETING_META_ADS_ENABLED=false
MARKETING_META_ADS_API_BASE_URL=https://graph.facebook.com
MARKETING_META_ADS_API_VERSION=v21.0
MARKETING_META_ADS_ACCESS_TOKEN=
MARKETING_META_ADS_ACCOUNT_ID=
MARKETING_META_ADS_DEFAULT_LOOKBACK_DAYS=30
MARKETING_META_ADS_TIMEOUT_SECONDS=20
MARKETING_META_ADS_MAX_PAGES=30
MARKETING_META_ADS_LIMIT=500

# AI budget readiness guardrails (recommendation-only)
MARKETING_AI_BUDGET_MIN_PURCHASE_SAMPLE=20
MARKETING_AI_BUDGET_MIN_WORKFLOW_ATTRIBUTION_SAMPLE=10
MARKETING_AI_BUDGET_AUTONOMOUS_ENABLED=false
MARKETING_AI_BUDGET_MAX_DAILY_SHIFT_PCT=15
MARKETING_AI_BUDGET_MAX_WEEKLY_SHIFT_PCT=25
MARKETING_AI_BUDGET_ROLLBACK_WINDOW_HOURS=24
MARKETING_AI_BUDGET_ANOMALY_ROAS_DROP_PCT=30
MARKETING_AI_BUDGET_HUMAN_APPROVAL_REQUIRED=true
MARKETING_AI_BUDGET_AUDIT_LOG_REQUIRED=true

# Birthday rewards
MARKETING_BIRTHDAY_REWARDS_ENABLED=true
MARKETING_BIRTHDAY_REWARD_TYPE=points
MARKETING_BIRTHDAY_POINTS_AMOUNT=50
MARKETING_BIRTHDAY_DISCOUNT_CODE_PREFIX=BDAY
MARKETING_BIRTHDAY_FREE_SHIPPING_CODE_PREFIX=BDAYSHIP
MARKETING_BIRTHDAY_CLAIM_WINDOW_DAYS_BEFORE=0
MARKETING_BIRTHDAY_CLAIM_WINDOW_DAYS_AFTER=14

# Twilio SMS provider
MARKETING_SMS_ENABLED=false
MARKETING_SMS_DRY_RUN=true
MARKETING_SMS_TEST_NUMBER=
MARKETING_MESSAGING_BULK_MAX_ESTIMATED_COST=250
MARKETING_MESSAGING_SMS_OUTBOUND_PER_SEGMENT=0.0083
MARKETING_MESSAGING_SMS_CARRIER_FEE_PER_SEGMENT=0.00395
MARKETING_MESSAGING_MMS_OUTBOUND_PER_MESSAGE=0.022
MARKETING_MESSAGING_MMS_CARRIER_FEE_PER_MESSAGE=0.009
MARKETING_MESSAGING_PREFER_MMS_WHEN_CHEAPER=true
MARKETING_MESSAGING_RESPONSES_ALLOW_START_RESUBSCRIBE=false
MARKETING_MESSAGING_RESPONSES_EMAIL_INBOUND_DOMAIN=
MARKETING_MESSAGING_RESPONSES_SENDGRID_INBOUND_TOKEN=
MARKETING_TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
# Legacy single-sender fallback. Keep these during migration if you have not moved to MARKETING_TWILIO_SENDERS yet.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
# Preferred multi-sender config. All senders share the single account SID/auth token above.
# MG sender: [{"key":"toll_free","label":"Toll-free","type":"toll_free","status":"active","enabled":true,"default":true,"phone_number_sid":"PN...","messaging_service_sid":"MG..."}]
# Direct sender: [{"key":"local","label":"Local","type":"local","status":"active","enabled":true,"phone_number_sid":"PN...","from_number":"+15555550123"}]
# Mixed sender config: [{"key":"toll_free","label":"Toll-free","type":"toll_free","status":"active","enabled":true,"default":true,"phone_number_sid":"PN...","messaging_service_sid":"MG..."},{"key":"local","label":"Local","type":"local","status":"pending","enabled":false,"default":false,"phone_number_sid":"PN...","from_number":"+15555550123"}]
MARKETING_TWILIO_SENDERS=
# Optional override for which configured sender should be the default.
MARKETING_TWILIO_DEFAULT_SENDER=
TWILIO_STATUS_CALLBACK_URL=
MARKETING_TWILIO_SMART_ENCODING=true
MARKETING_TWILIO_VERIFY_SIGNATURE=false
MARKETING_EMAIL_SMOKE_TEST_RECIPIENT=

# Stripe (guarded landlord billing-prep action only; no checkout/subscription lifecycle)
COMMERCIAL_STRIPE_CUSTOMER_SYNC_ENABLED=true
COMMERCIAL_STRIPE_SUBSCRIPTION_PREP_ENABLED=true
COMMERCIAL_STRIPE_LIVE_SUBSCRIPTION_SYNC_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_API_TIMEOUT=20

# Braintree (secondary/future mapping path; lifecycle inactive)
BRAINTREE_ENVIRONMENT=sandbox
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
