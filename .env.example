EVERBRANCH_AGREEMENT_STRIPE_TAX_ENABLED=false
EVERBRANCH_AGREEMENT_TAX_DECISION_CONFIRMED=false
EVERBRANCH_STRIPE_RELAY_PAYOUT_VERIFIED=false
# Set true only after the live Stripe endpoint is registered and a signed live-mode event is recorded.
EVERBRANCH_STRIPE_LIVE_WEBHOOK_VERIFIED=false
STRIPE_ACCOUNT_ID=
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
