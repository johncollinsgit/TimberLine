APP_NAME=Everbranch
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production canonical example: APP_URL=https://app.theeverbranch.com
FORTIFY_ALLOW_REGISTRATION=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_CONNECTION=null
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Local and test sessions stay host-only. Production defaults to sharing the
# session across the exact canonical base domain so authorized users can switch
# between app.theeverbranch.com and tenant hosts without signing in again.
SESSION_SHARE_CANONICAL_SUBDOMAINS=false
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# Canonical production and Shopify embedded admin cookies:
# SESSION_SHARE_CANONICAL_SUBDOMAINS=true
# SESSION_DOMAIN=theeverbranch.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none
# SESSION_PARTITIONED_COOKIE=true
SHOPIFY_EMBEDDED_PERF_PROFILING_ENABLED=false
SHOPIFY_EMBEDDED_PERF_SLOW_QUERY_MS=25
SHOPIFY_EMBEDDED_DEEP_PROFILE_ENABLED=false
SHOPIFY_EMBEDDED_JOURNEY_CACHE_TTL_SECONDS=60
SHOPIFY_API_VERSION=2026-01
SHOPIFY_SCOPES=read_products,read_orders,read_all_orders,read_reports,read_analytics,read_customers,write_customers,read_customer_merge,write_customer_merge,read_discounts,write_discounts,read_pixels,write_pixels,read_customer_events,unauthenticated_read_checkouts,unauthenticated_read_collection_listings,unauthenticated_read_product_listings,unauthenticated_read_selling_plans,unauthenticated_write_checkouts
CUSTOMER_MERGE_ENABLED=true
CUSTOMER_MERGE_TENANT_SLUGS=modern-forestry
CUSTOMER_MERGE_REQUIRE_WEBHOOK_VERIFICATION=true
SHOPIFY_ALLOW_ENV_TOKEN_FALLBACK=false
# Stores used when commands run without explicit --store.
SHOPIFY_ACTIVE_STORE_KEYS=retail
# Launch-critical store keys (retail-first launch model).
SHOPIFY_REQUIRED_STORE_KEYS=retail
#
# Retail store (primary storefront — REQUIRED in production; verify with `php artisan config:doctor`)
SHOPIFY_RETAIL_SHOP=
SHOPIFY_RETAIL_ACCESS_TOKEN=
SHOPIFY_RETAIL_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_RETAIL_CLIENT_ID=
SHOPIFY_RETAIL_CLIENT_SECRET=
SHOPIFY_RETAIL_EMBEDDED_CLIENT_ID=
SHOPIFY_RETAIL_EMBEDDED_CLIENT_SECRET=
SHOPIFY_RETAIL_TIMEZONE=America/New_York
#
# Wholesale embedded app install (Modern Forestry Wholesale)
# Add `wholesale` to the store-key lists above when you want launch checks to
# include the wholesale Shopify app connection too.
SHOPIFY_WHOLESALE_SHOP=s2vscq-rf.myshopify.com
SHOPIFY_WHOLESALE_ACCESS_TOKEN=
SHOPIFY_WHOLESALE_CLIENT_ID=
SHOPIFY_WHOLESALE_CLIENT_SECRET=
SHOPIFY_WHOLESALE_EMBEDDED_CLIENT_ID=
SHOPIFY_WHOLESALE_EMBEDDED_CLIENT_SECRET=
SHOPIFY_WHOLESALE_TIMEZONE=America/New_York

# Wholesale prospect discovery (Places API New)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1
GOOGLE_PLACES_ESTIMATED_COST_PER_REQUEST=0
GOOGLE_PLACES_DEFAULT_SAMPLE_SIZE=5
GOOGLE_PLACES_LARGE_SEARCH_THRESHOLD=40

# Square (legacy reconciliation — optional)
SQUARE_ACCESS_TOKEN=
SQUARE_BASE_URL=https://connect.squareup.com
SQUARE_ENVIRONMENT=production
SQUARE_LOCATION_ID=
SQUARE_OAUTH_CLIENT_ID=
SQUARE_OAUTH_CLIENT_SECRET=
SQUARE_OAUTH_REDIRECT_URI=
SQUARE_OAUTH_AUTHORIZATION_URL=https://connect.squareup.com/oauth2/authorize
SQUARE_OAUTH_TOKEN_URL=https://connect.squareup.com/oauth2/token
SQUARE_OAUTH_SCOPES="MERCHANT_PROFILE_READ ORDERS_READ ITEMS_READ"

# Dedicated multi-tenant Workflow Automations provider apps. Keep these
