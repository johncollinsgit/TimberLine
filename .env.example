# Twilio provider. Platform-managed tenants use isolated subaccounts and sender
# identities; these legacy sender values are migration-only.
MARKETING_TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
# Legacy single-sender fallback. Keep these during migration if you have not moved to MARKETING_TWILIO_SENDERS yet.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
# Preferred multi-sender config. All senders share the single account SID/auth token above.
# MG sender: [{"key":"toll_free","label":"Toll-free","type":"toll_free","status":"active","enabled":true,"default":true,"phone_number_sid":"PN...","messaging_service_sid":"MG..."}]
# Direct sender: [{"key":"local","label":"Local","type":"local","status":"active","enabled":true,"phone_number_sid":"PN...","from_number":"+15555550123"}]
# Mixed sender config: [{"key":"toll_free","label":"Toll-free","type":"toll_free","status":"active","enabled":true,"default":true,"phone_number_sid":"PN...","messaging_service_sid":"MG..."},{"key":"local","label":"Local","type":"local","status":"pending","enabled":false,"default":false,"phone_number_sid":"PN...","from_number":"+15555550123"}]
MARKETING_TWILIO_SENDERS=
# Optional override for which configured sender should be the default.
MARKETING_TWILIO_DEFAULT_SENDER=
TWILIO_STATUS_CALLBACK_URL=
MARKETING_TWILIO_SMART_ENCODING=true
MARKETING_TWILIO_VERIFY_SIGNATURE=false

# Stripe — Everbranch direct billing
# Paste complete Stripe-issued values with their prefixes intact:
# acct_... / pk_test_... or pk_live_... / sk_test_... or sk_live_... / whsec_...
# Use test keys locally. Store live values only in Forge/server secrets.
COMMERCIAL_STRIPE_CUSTOMER_SYNC_ENABLED=true
COMMERCIAL_STRIPE_SUBSCRIPTION_PREP_ENABLED=true
COMMERCIAL_STRIPE_LIVE_SUBSCRIPTION_SYNC_ENABLED=false
# Self-serve plan/add-on Checkout and signed-webhook entitlement fulfillment.
# Keep both false until live keys, the production webhook, tax posture, and payout evidence are verified.
EVERBRANCH_STRIPE_CHECKOUT_ACTIVE=false
EVERBRANCH_STRIPE_LIFECYCLE_MUTATIONS_ENABLED=false
EVERBRANCH_AGREEMENT_CHECKOUT_ENABLED=false
EVERBRANCH_AGREEMENT_CHECKOUT_TENANT_SLUGS=
EVERBRANCH_STRIPE_INVOICING_ENABLED=false
EVERBRANCH_STRIPE_INVOICING_TENANT_SLUGS=
# Explicit temporary production-host sandbox gate for Stripe test keys.
# Keep false for live billing; when true, require a concrete tenant allowlist.
