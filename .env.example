MODERN_FORESTRY_APNS_AUTH_KEY_PATH=
MODERN_FORESTRY_APNS_TIMEOUT=10
MODERN_FORESTRY_SUPPORT_ALERT_PHONE=+18646165468

VITE_APP_NAME="${APP_NAME}"

GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.theeverbranch.com/auth/google/callback
GOOGLE_LOGIN_AUTO_PROVISION=true
# GOOGLE_LOGIN_ALLOWED_DOMAINS=theforestrystudio.com

# Canonical host model (runtime + outbound): Everbranch
TENANCY_CANONICAL_SCHEME=https
TENANCY_CANONICAL_BASE_DOMAIN=theeverbranch.com
TENANCY_CANONICAL_PUBLIC_HOST=theeverbranch.com
TENANCY_CANONICAL_LANDLORD_HOST=app.theeverbranch.com
# Restricts tenant slug host resolution to explicit base domains.
# Include local dev domains when needed (example: theeverbranch.test).
TENANCY_TENANT_BASE_DOMAINS=theeverbranch.com

# Legacy hosts are edge-redirect only after cutover; keep runtime acceptance disabled.
TENANCY_LEGACY_BASE_DOMAINS=
TENANCY_LEGACY_PUBLIC_HOSTS=
TENANCY_LEGACY_LANDLORD_HOSTS=
TENANCY_LEGACY_PUBLIC_REDIRECT_ENABLED=false
TENANCY_LEGACY_PUBLIC_REDIRECT_STATUS=302

AUTH_FLAGSHIP_TENANT_SLUG=modern-forestry
AUTH_FLAGSHIP_HOSTS=app.theeverbranch.com,theeverbranch.com
# Optional JSON host -> tenant slug map, for example:
# AUTH_TENANT_HOST_MAP={"acme.theeverbranch.com":"acme"}
# Wholesale branded admin example:
# AUTH_TENANT_HOST_MAP={"admin.modernforestrywholesale.com":"modern-forestry"}
AUTH_TENANT_HOST_MAP=
# Landlord/operator host config:
# - TENANCY_LANDLORD_PRIMARY_HOST is used for canonical route generation
# - production canonical host: app.theeverbranch.com
# - local example host set: app.theeverbranch.test
# - keep roles as "admin" unless you intentionally broaden access
# - keep emails blank unless you want an extra explicit allowlist
TENANCY_LANDLORD_PRIMARY_HOST=app.theeverbranch.com
TENANCY_LANDLORD_HOSTS=app.theeverbranch.com
TENANCY_LANDLORD_OPERATOR_ROLES=admin
# Defaults to EVERBRANCH_BUD_SUPPORT_EMAIL when omitted. Comma-separate additional operators.
TENANCY_LANDLORD_OPERATOR_EMAILS=
AUTH_PORTAL_NAME=Everbranch
AUTH_FALLBACK_TENANT_LABEL="Modern Forestry"
PRODUCT_CONTACT_EMAIL_DOMAIN=theeverbranch.com
WHOLESALE_APPLICATION_REVIEW_EMAIL=modernforestryteam@gmail.com
WHOLESALE_APPLICATION_STOREFRONT_TENANT_SLUG=modern-forestry
EVERGROVE_CANONICAL_HOST=evergrovesoftware.com
EVERGROVE_PUBLIC_HOSTS=evergrovesoftware.com,www.evergrovesoftware.com
EVERGROVE_CONTACT_EMAIL=hello@evergrovesoftware.com
EVERGROVE_BOOKING_URL=

# Modern Forestry Customer Account OAuth (native iOS + Laravel brokered exchange)
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=
# Optional override; Laravel now prefers discovery from the storefront .well-known docs.
SHOPIFY_CUSTOMER_ACCOUNT_AUTHORIZATION_ENDPOINT=
SHOPIFY_CUSTOMER_ACCOUNT_TOKEN_ENDPOINT=
SHOPIFY_CUSTOMER_ACCOUNT_GRAPHQL_ENDPOINT=
SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=https://app.theeverbranch.com/api/mobile/v1/modern-forestry/auth/callback
SHOPIFY_CUSTOMER_ACCOUNT_CALLBACK_SCHEME=shop.20812479.modernforestry
SHOPIFY_CUSTOMER_ACCOUNT_SCOPES="openid email customer-account-api:full"
GOOGLE_GBP_ENABLED=false
GOOGLE_GBP_CLIENT_ID=
GOOGLE_GBP_CLIENT_SECRET=
GOOGLE_GBP_REDIRECT_URI=https://app.theeverbranch.com/marketing/candle-cash/google-business/callback
GOOGLE_GBP_SCOPES="https://www.googleapis.com/auth/business.manage"
# Workflow Automations (Asana -> Google Calendar). OAuth credential model:
#   - CLIENT id/secret + redirect URI + scopes = shared app registration -> OK to set globally here.
#   - REFRESH tokens + project + calendar = per-TENANT -> set in the Workflow Automations UI
#     (stored encrypted in tenant_marketing_settings). Do NOT put a tenant's refresh token here, or it
#     leaks to every other tenant via the effectiveCredentials() global fallback.
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_REDIRECT_URI=https://app.theeverbranch.com/marketing/providers-integrations/workflow-automations/google-calendar/callback
GOOGLE_CALENDAR_OAUTH_STATE_CACHE_STORE=file
GOOGLE_CALENDAR_OAUTH_SCOPES="https://www.googleapis.com/auth/calendar.events,https://www.googleapis.com/auth/calendar.calendarlist.readonly"
# Tenant-specific calendar for the Markets events sync (UpcomingMarketEventsService). Leave blank in
# the template and set per deployment. NOT used by the Workflow Automations module.
ASANA_SKYLIGHT_CALENDAR_ID=
ASANA_PERSONAL_ACCESS_TOKEN=
ASANA_API_BASE=https://app.asana.com/api/1.0
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=
ASANA_OAUTH_REFRESH_TOKEN=
ASANA_OAUTH_ACCESS_TOKEN=
ASANA_OAUTH_REDIRECT_URI=https://app.theeverbranch.com/marketing/providers-integrations/workflow-automations/asana/callback
ASANA_OAUTH_STATE_CACHE_STORE=file
ASANA_OAUTH_SCOPES="projects:read,tasks:read,workspaces:read"
AUTOMATION_WORKFLOWS_ENABLED=false
AUTOMATION_ASANA_TO_GCAL_ENABLED=false
# 0 = base template is inert; each tenant's instance runs from its tenant_marketing_settings row.
AUTOMATION_ASANA_TENANT_ID=0
AUTOMATION_ASANA_PROJECT_GID=
AUTOMATION_ASANA_MODIFIED_OVERLAP_MINUTES=5
AUTOMATION_ASANA_BOOTSTRAP_LOOKBACK_DAYS=14
AUTOMATION_ASANA_POLL_LIMIT=100
AUTOMATION_ASANA_MAX_TASKS_PER_RUN=500
AUTOMATION_GCAL_CALENDAR_ID=
AUTOMATION_GCAL_TIMEZONE=America/New_York
AUTOMATION_GCAL_DEFAULT_START_TIME=12:00:00
AUTOMATION_GCAL_DEFAULT_DURATION_MINUTES=60
AUTOMATION_GCAL_SKIP_COMPLETED_TASKS=true
FEATURE_MARKET_EVENTS_PANEL=true

