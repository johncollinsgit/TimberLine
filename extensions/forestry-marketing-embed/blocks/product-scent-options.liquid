{% liquid
  assign product_options_proxy = '/apps/forestry/product-options'
%}

{{ 'product-scent-options.css' | asset_url | stylesheet_tag }}

<div
  class="everbranch-product-options"
  data-everbranch-product-options
  data-proxy-endpoint="{{ product_options_proxy }}"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle | escape }}"
  data-heading="{{ block.settings.heading | escape }}"
  data-help-text="{{ block.settings.help_text | escape }}"
  hidden
>
  <div class="everbranch-product-options__loading" aria-live="polite">Loading scent options…</div>
</div>

<script src="{{ 'product-scent-options.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Everbranch scent options",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your scents"
    },
    {
      "type": "text",
      "id": "help_text",
      "label": "Help text",
      "default": "Choose one scent for each item in this bundle."
    }
  ]
}
{% endschema %}
