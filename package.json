{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "serve": "php artisan serve",
    "dev:full": "concurrently -k -n \"LARAVEL,VITE\" -c \"green,blue\" \"php artisan serve\" \"npm run dev\"",
    "shopify:app:dev": "shopify app dev",
    "shopify:app:deploy": "shopify app deploy",
    "shopify:app:info": "shopify app info",
    "qa:click-path": "node scripts/qa/click-path-audit.mjs",
    "qa:click-path:auth": "CLICK_PATH_CONFIG=tests/e2e/click-path-routes-auth.json node scripts/qa/click-path-audit.mjs"
  },
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.3",
    "@shopify/polaris": "^13.9.5",
    "@shopify/polaris-icons": "^9.3.1",
    "@shopify/web-pixels-extension": "^2.18.0",
    "@tailwindcss/vite": "^4.1.11",
    "autoprefixer": "^10.4.20",
    "axios": "^1.7.4",
    "chart.js": "^4.5.1",
    "cmdk": "^1.1.1",
    "fuse.js": "^7.2.0",
    "laravel-vite-plugin": "^2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.0.7",
    "vite": "^7.0.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.9.5",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
    "lightningcss-linux-x64-gnu": "^1.29.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "playwright": "^1.54.2"
  }
}
